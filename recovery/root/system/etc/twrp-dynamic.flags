# System
/system         auto    system                                                  flags=display="System";logical
/vendor         auto    vendor                                                  flags=display="Vendor";logical
/product        auto    product                                                 flags=display="Product";logical
/system_ext     auto    system_ext                                              flags=display="System_EXT";logical
/odm            auto    odm                                                     flags=display="ODM";logical
